<?xml version="1.0"?>
<ruleset>
	<file>.</file>
	<arg name="extensions" value="php" />
	<config name="testVersion" value="8.1-" />
	<rule ref="Dekode">
		<!-- PrefixAllGlobals is noisy for plugin bootstrap files; re-enable when prefixes are standardized -->
		<exclude name="WordPress.NamingConventions.PrefixAllGlobals"/>
	</rule>
	<!-- Third-party code -->
	<exclude-pattern>inc/updater/</exclude-pattern>
	<!-- Template view: mostly HTML, no strict types -->
	<exclude-pattern>src/templates/views/</exclude-pattern>
</ruleset>
