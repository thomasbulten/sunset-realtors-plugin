{
	"version": "1.0.0",
	"apiVersion": 2,
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"name": "bp-plugin/team-grid",
	"title": "Team Grid",
	"description": "List team members",
	"category": "common",
	"supports": {
		"anchor": true,
		"html": false,
		"align": ["wide","full"],
		"typography": {
			"fontSize": false,
			"textAlign": [ "left", "center", "right" ],
			"lineHeight": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"keywords": ["team-member", "team", "grid"],
	"attributes": {
		"anchor": {
			"type": "string"
		},
		"textAlign": {
			"type": "string",
			"default": "left"
		},
		"orderBy": {
			"type": "string"
		},
		"order": {
			"type": "string"
		}
	},
	"example": {
	    "viewportWidth": 1440,
        "attributes": {}
    },
	"style": "file:./style-index.css",
	"script": "file:./script.js",
	"editorStyle": "file:./style.css",
	"editorScript": "file:./index.js"
}
